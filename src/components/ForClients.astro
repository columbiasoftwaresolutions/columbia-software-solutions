---
import { CLIENT_EMAIL } from "../content";
---

<section id="for-clients" class="reveal py-20 md:py-24 border-b border-line">
  <div class="container-x">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-6">
        <p class="eyebrow">For NYC nonprofits & small businesses</p>
        <h2
          class="display mt-5 text-[clamp(32px,4.2vw,56px)] text-fg max-w-[14ch]"
        >
          For clients.
        </h2>
      </div>

      <div class="md:col-span-6 md:pt-3">
        <p class="text-[17px] md:text-[18px] leading-[1.6] text-fg/85">
          Scope a project with us. We match a 3–4 person team. You ship in a
          semester. No cost.
        </p>

        <a href={`mailto:${CLIENT_EMAIL}`} class="btn-primary mt-9">
          Work with us
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
