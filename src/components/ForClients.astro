---
import { CLIENT_EMAIL } from "../content";
---

<section id="for-clients" class="reveal py-24 md:py-32 border-b border-line">
  <div class="container-x">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-7">
        <p class="eyebrow">For NYC nonprofits & small businesses</p>
        <h2
          class="display mt-5 text-[clamp(36px,5.4vw,72px)] text-fg max-w-[22ch]"
        >
          Software you need. Built by engineers who care. Free.
        </h2>
      </div>

      <div class="md:col-span-5 md:pt-3">
        <p class="text-[17px] md:text-[18px] leading-[1.6] text-fg/85">
          Scope a project with us. We match a 3–4 person team led by a senior
          engineer. You ship in a semester. We've worked with nonprofits and
          small businesses across NYC. No cost.
        </p>

        <a href={`mailto:${CLIENT_EMAIL}`} class="btn-primary mt-9">
          Work with us
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
