---
import { caseStudies } from "../content";

// Pass marker data to client-side script as a JSON payload — keeps
// the data source unified with the case studies array.
const markerData = caseStudies.map((c) => ({
  id: c.id,
  name: c.clientName,
  tag: c.tagline,
  coords: c.coords,
  status: c.status,
}));
---

<div class="map-shell">
  <div
    id="hero-map"
    class="hero-map"
    aria-label="Map of Columbia Software Solutions client locations"
    data-markers={JSON.stringify(markerData)}
  ></div>
  <div class="legend" aria-hidden="true">
    <span class="legend-row">
      <span class="legend-shipped"></span>
      <span>Shipped</span>
    </span>
    <span class="legend-row">
      <span class="legend-progress"></span>
      <span>In progress</span>
    </span>
  </div>
</div>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<style>
  .map-shell {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 440px;
    margin: 0 auto;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.45),
      0 0 60px rgba(13, 60, 252, 0.18);
  }
  .hero-map {
    position: absolute;
    inset: 0;
    background: #0a0a0a;
    z-index: 1;
  }

  /* ---- Marker variants ---- */
  :global(.css-marker) {
    position: relative;
  }
  /* Shipped: filled blue dot + pulsing ring */
  :global(.css-marker--shipped .dot) {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 14px;
    height: 14px;
    margin: -7px 0 0 -7px;
    border-radius: 50%;
    background: #0d3cfc;
    border: 2px solid #ffffff;
    box-shadow: 0 0 10px rgba(13, 60, 252, 0.7);
    z-index: 2;
  }
  :global(.css-marker--shipped .ring) {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 14px;
    height: 14px;
    margin: -7px 0 0 -7px;
    border-radius: 50%;
    background: rgba(13, 60, 252, 0.4);
    animation: marker-pulse 2.4s ease-out infinite;
  }
  /* In progress: hollow ring, no pulse */
  :global(.css-marker--in-progress .dot) {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 14px;
    height: 14px;
    margin: -7px 0 0 -7px;
    border-radius: 50%;
    background: transparent;
    border: 2px solid #ffffff;
    box-shadow: 0 0 8px rgba(13, 60, 252, 0.45);
    z-index: 2;
  }
  :global(.css-marker--in-progress .ring) {
    display: none;
  }
  @keyframes marker-pulse {
    0% { transform: scale(0.6); opacity: 0.7; }
    100% { transform: scale(2.6); opacity: 0; }
  }
  :global(.css-marker:hover .dot) {
    transform: scale(1.18);
    box-shadow: 0 0 16px rgba(13, 60, 252, 0.95);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  /* ---- Popup styling ---- */
  :global(.leaflet-popup-content-wrapper) {
    background: rgba(22, 22, 22, 0.96) !important;
    color: #fff !important;
    border: 1px solid rgba(255, 255, 255, 0.12) !important;
    border-radius: 6px !important;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.55) !important;
    padding: 0 !important;
  }
  :global(.leaflet-popup-tip) {
    background: rgba(22, 22, 22, 0.96) !important;
    border: 1px solid rgba(255, 255, 255, 0.12) !important;
  }
  :global(.leaflet-popup-content) {
    margin: 10px 14px !important;
    line-height: 1.45 !important;
  }
  :global(.css-popup-name) {
    display: block;
    font-family:
      "Geist Sans",
      -apple-system,
      sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }
  :global(.css-popup-tag) {
    display: block;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-top: 2px;
  }
  :global(.css-popup-status) {
    display: inline-block;
    margin-top: 6px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.55);
    padding: 2px 7px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
  }
  :global(.css-popup-cta) {
    display: block;
    font-family:
      "Geist Sans",
      sans-serif;
    font-size: 11px;
    color: #7aa8ff;
    margin-top: 6px;
  }

  /* ---- Leaflet chrome (dark) ---- */
  :global(.leaflet-control-attribution) {
    background: rgba(0, 0, 0, 0.55) !important;
    color: rgba(255, 255, 255, 0.45) !important;
    font-size: 9px !important;
    padding: 2px 6px !important;
  }
  :global(.leaflet-control-attribution a) {
    color: rgba(255, 255, 255, 0.6) !important;
  }
  :global(.leaflet-bar a) {
    background: rgba(22, 22, 22, 0.92) !important;
    color: rgba(255, 255, 255, 0.85) !important;
    border-color: rgba(255, 255, 255, 0.1) !important;
  }
  :global(.leaflet-bar a:hover) {
    background: rgba(40, 40, 40, 0.96) !important;
  }

  /* ---- Legend (bottom-left) ---- */
  .legend {
    position: absolute;
    bottom: 12px;
    left: 14px;
    z-index: 500;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(22, 22, 22, 0.82);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 6px 10px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    pointer-events: none;
  }
  .legend-row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .legend-shipped {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #0d3cfc;
    border: 1.5px solid #fff;
    box-shadow: 0 0 6px rgba(13, 60, 252, 0.7);
  }
  .legend-progress {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: transparent;
    border: 1.5px solid #fff;
  }
</style>

<script>
  import L from "leaflet";

  type MarkerInput = {
    id: string;
    name: string;
    tag: string;
    coords: [number, number];
    status: "shipped" | "in-progress";
  };

  const init = () => {
    const el = document.getElementById("hero-map") as HTMLElement | null;
    if (!el || el.dataset.init === "true") return;
    el.dataset.init = "true";

    let markers: MarkerInput[] = [];
    try {
      markers = JSON.parse(el.dataset.markers ?? "[]");
    } catch {
      markers = [];
    }
    if (markers.length === 0) return;

    const map = L.map(el, {
      zoomControl: true,
      attributionControl: true,
      scrollWheelZoom: false,
      dragging: true,
      tap: true,
    });

    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
      {
        attribution:
          '&copy; <a href="https://carto.com/attributions">CARTO</a> &middot; OSM',
        maxZoom: 19,
        subdomains: "abcd",
      },
    ).addTo(map);

    const group = L.featureGroup();
    for (const m of markers) {
      const icon = L.divIcon({
        className: `css-marker css-marker--${m.status}`,
        html: '<div class="ring"></div><div class="dot"></div>',
        iconSize: [14, 14],
        iconAnchor: [7, 7],
      });
      const marker = L.marker(m.coords, { icon }).addTo(group);
      const statusLabel =
        m.status === "shipped" ? "Shipped" : "In progress";
      marker.bindPopup(
        `<span class="css-popup-name">${m.name}</span>` +
          `<span class="css-popup-tag">${m.tag}</span>` +
          `<span class="css-popup-status">${statusLabel}</span>` +
          `<a class="css-popup-cta" href="#case-${m.id}">View on page →</a>`,
        { closeButton: false, offset: L.point(0, -4) },
      );
      marker.on("mouseover", () => marker.openPopup());
      marker.on("click", () => {
        const target = document.getElementById(`case-${m.id}`);
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    }
    group.addTo(map);

    // Fit all markers with comfortable padding. maxZoom keeps the
    // view honest when pins are very close together (NYC pair).
    map.fitBounds(group.getBounds(), { padding: [44, 44], maxZoom: 11 });

    // Enable scroll-wheel zoom only after the user explicitly clicks
    // into the map, so the map doesn't hijack page scroll.
    map.on("click", () => map.scrollWheelZoom.enable());
    map.on("focus", () => map.scrollWheelZoom.enable());
  };

  init();
  document.addEventListener("astro:after-swap", init);
</script>
