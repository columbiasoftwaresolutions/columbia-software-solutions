---
import { ctas } from "../content";
---

<!-- Fixed full-viewport dark fill that grows in when FinalCTA enters
     the viewport. Sits behind the section content (z-index 30) but
     above all other page sections (z auto) so it visually covers the
     light Team section above and Footer below as it grows. -->
<div id="cta-fill" class="cta-fill" aria-hidden="true"></div>

<section
  class="reveal cta-section relative isolate bg-hero-bg text-hero-fg py-20 md:py-28"
  data-nav-merge="true"
>
  <div class="container-x relative z-10">
    <div class="cta-content">
      <p class="eyebrow !text-white/55">Build with us</p>
      <h2
        class="display mt-5 text-[clamp(44px,7vw,96px)] text-white max-w-[18ch]"
      >
        {ctas.final.headline}
      </h2>
      <p class="mt-6 max-w-[60ch] text-[17px] md:text-[19px] text-white/80">
        {ctas.final.subhead}
      </p>
      <a href={ctas.final.cta.href} class="btn-light mt-9">
        {ctas.final.cta.label}
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <!-- Subtle dot grid backdrop -->
  <svg
    class="absolute inset-0 -z-0 h-full w-full opacity-25"
    aria-hidden="true"
  >
    <defs>
      <pattern
        id="dot-grid"
        x="0"
        y="0"
        width="32"
        height="32"
        patternUnits="userSpaceOnUse"
      >
        <circle cx="1.5" cy="1.5" r="1.2" fill="rgba(255,255,255,0.18)"></circle>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#dot-grid)"></rect>
  </svg>
</section>

<style>
  .cta-fill {
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background: var(--hero-bg);
    z-index: 30;
    pointer-events: none;
    /* Origin at the bottom — dark grows up from below, sinks back down. */
    transform-origin: center bottom;
    transform: scaleY(0);
    /* Short transition only — main motion comes from scroll-tied
       progress in JS, so fast scrolls track 1:1 without queuing. */
    transition: transform 120ms linear;
    will-change: transform;
  }

  /* The section sits above the fill so its content is always visible. */
  .cta-section {
    z-index: 40;
  }

  /* Content fades + slides up as the fill grows. Tied to scroll
     progress in JS via CSS custom property --p (0..1). */
  .cta-content {
    --p: 0;
    opacity: calc(max(0, (var(--p) - 0.45)) * 1.8);
    transform: translateY(calc((1 - var(--p)) * 24px));
    transition: opacity 200ms linear, transform 200ms linear;
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-fill {
      transition: opacity 200ms ease;
      transform: scaleY(1);
      opacity: 0;
    }
    .cta-fill.is-on {
      opacity: 1;
    }
  }
</style>

<script>
  // Activate the dark fill when the FinalCTA section is "behind" the
  // nav (its top has scrolled above the nav's bottom). Same trigger
  // as the nav merge, kept here so this component owns its visual.
  const fill = document.getElementById("cta-fill");
  const nav = document.getElementById("site-nav");
  const section = document.querySelector(".cta-section") as HTMLElement | null;

  // Scroll-tied progress: scaleY tracks FinalCTA's viewport position
  // through two phases:
  //   Phase 1 — section starts entering -> thin black bar (5% height)
  //   Phase 2 — section advances toward center -> bar grows to full
  // Fast scrolls map 1:1 (no queued transition), so no glitch.
  const BAR_MIN = 0.05;
  const content = section?.querySelector<HTMLElement>(".cta-content") ?? null;
  let ticking = false;

  const apply = () => {
    ticking = false;
    if (!fill || !section) return;
    const rect = section.getBoundingClientRect();
    const vh = window.innerHeight;

    // Anchor points: when section.top hits each, what progress?
    const ENTER = vh * 1.0;   // 0
    const BAR   = vh * 0.5;   // BAR_MIN (thin bar visible)
    const FULL  = vh * 0.1;   // 1 (full)

    let progress = 0;
    if (rect.top >= ENTER) {
      progress = 0;
    } else if (rect.top >= BAR) {
      // Phase 1: 0 -> BAR_MIN
      const t = (ENTER - rect.top) / (ENTER - BAR);
      progress = t * BAR_MIN;
    } else if (rect.top > FULL) {
      // Phase 2: BAR_MIN -> 1
      const t = (BAR - rect.top) / (BAR - FULL);
      progress = BAR_MIN + (1 - BAR_MIN) * Math.max(0, Math.min(1, t));
    } else {
      progress = 1;
    }
    if (rect.bottom < 0) progress = 0;
    if (progress < 0) progress = 0;
    if (progress > 1) progress = 1;

    fill.style.transform = `scaleY(${progress.toFixed(4)})`;
    if (content) content.style.setProperty("--p", progress.toFixed(4));
    if (nav) nav.dataset.merge = progress > 0.5 ? "true" : "false";
  };

  const check = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(apply);
  };

  check();
  window.addEventListener("scroll", check, { passive: true });
  window.addEventListener("resize", check, { passive: true });
  document.addEventListener("astro:after-swap", check);
</script>
