---
import { ctas } from "../content";
---

<section class="reveal final-cta border-t border-line py-24 md:py-32">
  <div class="container-x">
    <p class="eyebrow">Build with us</p>
    <h2
      class="display mt-5 text-[clamp(44px,7vw,88px)] text-fg max-w-[16ch]"
    >
      {ctas.final.headline}
    </h2>
    <p class="mt-6 max-w-[52ch] text-[17px] md:text-[19px] leading-[1.5] text-muted">
      {ctas.final.subhead}
    </p>
    <a
      href={ctas.final.cta.href}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary mt-9"
    >
      {ctas.final.cta.label}
      <span class="arrow" aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  /* Soft blue wash so the closing section reads as a deliberate moment
     without a heavy solid block. */
  .final-cta {
    background:
      linear-gradient(
        180deg,
        rgba(63, 120, 189, 0.05) 0%,
        rgba(63, 120, 189, 0.02) 100%
      ),
      var(--bg);
  }
</style>
