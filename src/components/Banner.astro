---
import { WAITLIST_URL } from "../content";
---

<a
  href={WAITLIST_URL}
  target="_blank"
  rel="noopener noreferrer"
  class="banner block"
  aria-label="Join the Fall 2026 waitlist"
>
  <div class="container-x flex h-9 items-center justify-center gap-2 text-[12px] tracking-wide text-white">
    <span>Fall 2026 waitlist is open</span>
    <span aria-hidden="true">→</span>
  </div>
</a>

<style>
  .banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    height: 36px;
    background: var(--accent);
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    text-decoration: none;
    transition: opacity 200ms ease;
  }
  .banner:hover {
    opacity: 0.92;
  }
</style>
