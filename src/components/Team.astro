---
import { team } from "../content";
import Headshot from "./Headshot.astro";
---

<section id="team" class="reveal py-20 md:py-24 border-b border-line">
  <div class="container-x">
    <p class="eyebrow">Team</p>
    <h2 class="display mt-5 text-[clamp(34px,5vw,64px)] text-fg max-w-[18ch]">
      Founders.
    </h2>

    <ul class="mt-12 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      {
        team.map((m) => (
          <li class="flex flex-col">
            <Headshot name={m.name} src={m.image} alt={m.imageAlt} aspect="4/5" />
            <h3 class="display mt-5 text-[20px] text-fg">{m.name}</h3>
            <p class="mt-1 text-[11px] uppercase tracking-eyebrow text-muted">
              {m.role}
            </p>
            <p class="mt-3 text-[14px] leading-[1.55] text-fg/75">{m.bio}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
