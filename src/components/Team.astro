---
import { team } from "../content";
---

<section id="team" class="reveal py-24 md:py-32 border-b border-line">
  <div class="container-x">
    <p class="eyebrow">Team</p>
    <h2 class="display mt-5 text-[clamp(34px,5vw,64px)] text-fg max-w-[18ch]">
      Founders.
    </h2>

    <ul class="mt-14 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      {
        team.map((m) => (
          <li class="flex flex-col">
            {/* TODO: Ethan to add headshot */}
            <div
              class="aspect-square w-full bg-bg-alt border border-line flex items-center justify-center text-[11px] uppercase tracking-eyebrow text-muted"
              role="img"
              aria-label={m.imageAlt}
            >
              Placeholder
            </div>
            <h3 class="display mt-5 text-[22px] text-fg">{m.name}</h3>
            <p class="mt-1 text-[13px] uppercase tracking-eyebrow text-muted">
              {m.role}
            </p>
            <p class="mt-3 text-[15px] leading-[1.55] text-fg/80">{m.bio}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
