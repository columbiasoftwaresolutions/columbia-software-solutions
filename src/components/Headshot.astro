---
/**
 * Headshot — renders an <img> if `src` is provided, otherwise a styled
 * placeholder showing the person's initials in display font on the
 * site's bg-alt color. Swap to a real photo by adding `src` to the
 * content.ts entry.
 *
 * Default aspect is 4:5 (portrait) to match advisor/team layout.
 */
interface Props {
  name: string;
  src?: string | null;
  alt?: string;
  aspect?: string;
}
const { name, src, alt, aspect = "4/5" } = Astro.props;

function initials(n: string): string {
  const parts = n.trim().split(/\s+/).filter(Boolean);
  if (parts.length === 0) return "?";
  if (parts.length === 1) return parts[0]!.charAt(0).toUpperCase();
  return (
    parts[0]!.charAt(0) + parts[parts.length - 1]!.charAt(0)
  ).toUpperCase();
}
---

{
  src ? (
    <img
      src={src}
      alt={alt ?? `${name} headshot`}
      class="headshot-img"
      style={`aspect-ratio: ${aspect};`}
      loading="lazy"
    />
  ) : (
    <div
      class="headshot-placeholder"
      style={`aspect-ratio: ${aspect};`}
      role="img"
      aria-label={alt ?? `${name} (headshot pending)`}
    >
      <span class="headshot-initials display">{initials(name)}</span>
      <span class="headshot-mark">Photo pending</span>
    </div>
  )
}

<style>
  .headshot-img {
    width: 100%;
    display: block;
    object-fit: cover;
    background: var(--bg-alt);
    border: 1px solid var(--line);
  }

  .headshot-placeholder {
    position: relative;
    width: 100%;
    background:
      linear-gradient(
        180deg,
        rgba(241, 239, 237, 0.85) 0%,
        rgba(225, 222, 218, 0.85) 100%
      ),
      var(--bg-alt);
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .headshot-initials {
    font-size: clamp(48px, 5vw, 72px);
    color: rgba(30, 30, 30, 0.45);
    letter-spacing: -0.04em;
    line-height: 1;
    user-select: none;
  }

  .headshot-mark {
    position: absolute;
    bottom: 10px;
    left: 12px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px;
    color: rgba(30, 30, 30, 0.35);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
