---
import { nav, hero, WAITLIST_URL } from "../content";
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-9 z-50 transition-colors duration-200"
  data-mode="top"
  data-brand="long"
>
  <div class="container-x flex h-16 items-center justify-between">
    <a
      href="/"
      class="flex items-center gap-2.5 font-display text-[16px] md:text-[18px] font-semibold uppercase tracking-[0.02em] leading-none"
      data-nav-link
      aria-label="Columbia Software Solutions home"
    >
      <img
        src="/logo.png"
        alt=""
        width="32"
        height="32"
        class="nav-lion"
        aria-hidden="true"
      />
      <span
        id="brand-text"
        data-long="Columbia Software Solutions"
        data-short="CSS"
        class="brand-text"
      >Columbia Software Solutions</span>
    </a>

    <div class="flex items-center gap-8">
      <nav
        class="hidden items-center gap-7 md:flex"
        aria-label="Primary navigation"
      >
        {
          nav.links.map((link) => (
            <a
              href={link.href}
              data-nav-link
              class="text-[14px] transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <a
        href={WAITLIST_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-nav-cta
        class="inline-flex items-center gap-1.5 md:gap-2 rounded-full px-3 md:px-4 py-1.5 md:py-2 text-[11px] md:text-[13px] font-medium transition-all duration-200 whitespace-nowrap"
      >
        {hero.primaryCta.label}
        <span class="hidden md:inline" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>

<style>
  .nav-lion {
    width: 32px;
    height: 32px;
    object-fit: contain;
    display: block;
  }

  /* Brand text uses tabular numerals + a fixed-width cap so the
     scramble doesn't cause layout jitter. */
  .brand-text {
    display: inline-block;
    white-space: nowrap;
    will-change: contents;
  }

  /* Two states, both on the light theme:
     "top"      -> transparent bar over the paper hero
     "scrolled" -> paper bar with blur + hairline once the user scrolls */
  #site-nav {
    background: transparent;
    border-bottom: 1px solid transparent;
  }
  #site-nav[data-mode="scrolled"] {
    background: rgba(230, 227, 224, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  #site-nav [data-nav-link] {
    color: rgba(30, 30, 30, 0.7);
  }
  #site-nav [data-nav-link]:hover {
    color: var(--fg);
  }
  #site-nav [data-nav-cta] {
    background: var(--accent);
    color: #ffffff;
  }
  #site-nav [data-nav-cta]:hover {
    background: var(--accent-dark);
  }

  /* Mobile only: hide the CTA pill while the long brand text is
     showing. Once it scrambles down to "CSS", the CTA fades in. */
  @media (max-width: 767px) {
    #site-nav[data-brand="long"] [data-nav-cta] {
      opacity: 0;
      transform: scale(0.85);
      pointer-events: none;
      visibility: hidden;
    }
  }
</style>

<script>
  // Re-query on every page (after-swap) because Astro view transitions
  // replace DOM nodes — stale references point to detached elements.
  let nav: HTMLElement | null = document.getElementById("site-nav");
  let brand: HTMLElement | null = document.getElementById("brand-text");
  let LONG = brand?.dataset.long ?? "Columbia Software Solutions";
  let SHORT = brand?.dataset.short ?? "CSS";
  const SCRAMBLE_THRESHOLD = 80;

  const update = () => {
    if (!nav) return;
    nav.dataset.mode = window.scrollY > 12 ? "scrolled" : "top";
  };

  // -----------------------------------------------------------------
  // Brand-text scramble. As the user scrolls past SCRAMBLE_THRESHOLD,
  // the wordmark morphs from "Columbia Software Solutions" -> "CSS"
  // by scrambling chars and shrinking length. Reverses on scroll back.
  // -----------------------------------------------------------------
  const GLYPHS = "@#%&$+*/={}<>?~!|^";
  let brandState: "long" | "short" = "long";
  let animFrame = 0;

  function scrambleMorph(
    from: string,
    to: string,
    duration: number,
    onDone?: () => void,
  ) {
    if (!brand) return;
    const startTime = performance.now();
    const localFrame = ++animFrame;
    const fromLen = from.length;
    const toLen = to.length;

    const tick = (now: number) => {
      // If another animation has started, abort this one.
      if (localFrame !== animFrame) return;
      const t = Math.min((now - startTime) / duration, 1);

      if (t < 1) {
        const len = Math.max(
          toLen,
          Math.round(fromLen + (toLen - fromLen) * t),
        );
        const out: string[] = [];
        for (let i = 0; i < len; i++) {
          if (t > 0.78 && i < toLen) {
            out.push(to[i]!);
          } else if (t > 0.32) {
            out.push(GLYPHS[Math.floor(Math.random() * GLYPHS.length)]!);
          } else {
            // Mostly original, with rising probability of scramble.
            const scrambleChance = t / 0.32;
            if (Math.random() < scrambleChance) {
              out.push(GLYPHS[Math.floor(Math.random() * GLYPHS.length)]!);
            } else {
              out.push(from[i] ?? " ");
            }
          }
        }
        brand.textContent = out.join("");
        requestAnimationFrame(tick);
      } else {
        brand.textContent = to;
        onDone?.();
      }
    };

    requestAnimationFrame(tick);
  }

  function checkBrand() {
    if (!brand) return;
    const y = window.scrollY;
    if (y > SCRAMBLE_THRESHOLD && brandState === "long") {
      brandState = "short";
      // Toggle mobile CTA visibility partway through the scramble so it
      // fades in alongside the now-compact wordmark instead of sitting
      // there awkwardly while letters are still scrambling.
      setTimeout(() => {
        if (nav && brandState === "short") nav.dataset.brand = "short";
      }, 500);
      scrambleMorph(LONG, SHORT, 1100);
    } else if (y < 20 && brandState === "short") {
      brandState = "long";
      if (nav) nav.dataset.brand = "long";
      scrambleMorph(SHORT, LONG, 1200);
    }
  }

  update();
  checkBrand();
  window.addEventListener(
    "scroll",
    () => {
      update();
      checkBrand();
    },
    { passive: true },
  );
  document.addEventListener("astro:after-swap", () => {
    // Astro view transitions swap the DOM — re-query the elements so
    // we're not holding references to detached nodes from the prior
    // page render. Without this, brand.textContent updates the OLD
    // (removed) element and the visible header stays stuck.
    nav = document.getElementById("site-nav");
    brand = document.getElementById("brand-text");
    if (brand) {
      LONG = brand.dataset.long ?? "Columbia Software Solutions";
      SHORT = brand.dataset.short ?? "CSS";
    }
    update();
    brandState = "long";
    if (brand) brand.textContent = LONG;
    if (nav) nav.dataset.brand = "long";
    checkBrand();
  });
</script>
