---
import { advisors } from "../content";
---

<section id="advisors" class="reveal py-24 md:py-32 border-b border-line">
  <div class="container-x">
    <p class="eyebrow">Founding Advisory Board — Announcing</p>
    <h2 class="display mt-5 max-w-[18ch] text-[clamp(34px,5vw,64px)] text-fg">
      The operators behind the work.
    </h2>
    <p class="mt-6 max-w-[60ch] text-[17px] md:text-[18px] leading-[1.55] text-muted">
      Senior advisors from venture, AI, and B2B SaaS keep us honest. Code
      review, scope review, post-mortems — same way they ran their own teams.
    </p>

    <ul class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
      {
        advisors.map((a) => (
          <li class="flex flex-col">
            <!-- TODO: Ethan to add headshot -->
            <div
              class="aspect-square w-full bg-bg-alt border border-line flex items-center justify-center text-[11px] uppercase tracking-eyebrow text-muted"
              role="img"
              aria-label={a.imageAlt}
            >
              Placeholder
            </div>
            <h3 class="display mt-5 text-[24px] text-fg">{a.name}</h3>
            <p class="mt-1 text-[13px] uppercase tracking-eyebrow text-muted">
              {a.role}
            </p>
            <p class="mt-3 text-[15px] leading-[1.55] text-fg/80">{a.bio}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
