---
import { hero, WAITLIST_URL } from "../content";
import HeroMap from "./HeroMap.astro";

const tabs = [
  { label: "Scope" },
  { label: "Match" },
  { label: "Build" },
  { label: "Review" },
  { label: "Ship" },
  { label: "Hand off" },
];
---

<section
  id="top"
  class="relative isolate overflow-hidden bg-hero-bg text-hero-fg"
>
  <div class="container-x relative pt-36 md:pt-40 pb-10 flex flex-col min-h-screen">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center flex-1">
      <div class="md:col-span-7 lg:col-span-7 relative z-10">
        <h1
          class="display hero-rise hero-rise-1 text-[clamp(44px,6.4vw,92px)] text-fg"
        >
          Free software<br />for <span class="nyc-route-label"
            >NYC<svg
              class="nyc-route"
              viewBox="0 0 160 24"
              preserveAspectRatio="none"
              aria-hidden="true"
            >
              <path
                class="nyc-route-base"
                d="M3 7 C31 7, 36 18, 65 18 S100 6, 128 9 S145 16, 157 14"
              />
              <path
                class="nyc-route-traveler"
                d="M3 7 C31 7, 36 18, 65 18 S100 6, 128 9 S145 16, 157 14"
              />
              <circle class="nyc-route-stop" cx="157" cy="14" r="3.5" />
            </svg></span
          >.
        </h1>

        <p
          class="hero-rise hero-rise-2 mt-7 max-w-[58ch] text-[16px] md:text-[18px] leading-[1.55] text-muted"
        >
          <span class="text-fg font-medium">Columbia Software Solutions:</span>
          {" "}free software for nonprofits and small businesses. We scope,
          build, and ship in 1–2 months. Built and run by Columbia students.
          Started in NYC, Spring 2026.
        </p>

        <div class="hero-rise hero-rise-3 mt-9 flex flex-wrap items-center gap-3">
          <a
            href={WAITLIST_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            {hero.primaryCta.label}
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a
            href={hero.ghostCta.href}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-ghost"
          >
            {hero.ghostCta.label}
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <div
        class="md:col-span-5 lg:col-span-5 hero-rise hero-rise-4 flex justify-center md:justify-end"
      >
        <div class="w-full max-w-[440px]">
          <HeroMap />
        </div>
      </div>
    </div>

    <!-- Tab bar -->
    <div
      class="hero-rise hero-rise-5 mt-12 md:mt-16 border-t border-line pt-4"
    >
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-6 gap-y-3">
        {
          tabs.map((t) => (
            <div class="text-fg/80 text-[13px] font-medium tracking-tight">
              {t.label}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .nyc-route-label {
    position: relative;
    display: inline-block;
    padding-bottom: 0.16em;
  }

  .nyc-route {
    position: absolute;
    bottom: -0.02em;
    left: 0;
    width: 100%;
    height: 0.21em;
    overflow: visible;
  }

  .nyc-route-base,
  .nyc-route-traveler {
    fill: none;
    stroke: var(--accent);
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }

  .nyc-route-base {
    stroke-width: 1.5;
  }

  .nyc-route-traveler {
    stroke-width: 3;
    stroke-dasharray: 12 260;
    animation: nyc-route-travel 3.6s linear infinite;
  }

  .nyc-route-stop {
    fill: var(--accent);
  }

  @keyframes nyc-route-travel {
    to {
      stroke-dashoffset: -272;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nyc-route-traveler {
      animation: none;
    }
  }
</style>
