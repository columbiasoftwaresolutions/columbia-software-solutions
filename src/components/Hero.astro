---
import { hero, WAITLIST_URL } from "../content";
import HeroCubes from "./HeroCubes.astro";

const tabs = [
  { label: "Scope", subtitle: "the problem" },
  { label: "Match", subtitle: "a team" },
  { label: "Build", subtitle: "in a semester" },
  { label: "Mentor", subtitle: "by operators" },
  { label: "Ship", subtitle: "to production" },
  { label: "Hand off", subtitle: "for free" },
];
---

<section
  id="top"
  class="relative isolate overflow-hidden bg-hero-bg text-hero-fg"
>
  <!-- Promo banner -->
  <div class="border-b border-white/10 bg-hero-accent/95">
    <div class="container-x flex h-9 items-center justify-center text-[12px] tracking-wide text-white">
      <a
        href={WAITLIST_URL}
        class="inline-flex items-center gap-2 transition-opacity hover:opacity-100 opacity-90"
      >
        <span>Announcing our Founding Advisory Board — BCV · OpenAI · HBS</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <div class="container-x relative pt-24 md:pt-32 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center min-h-[460px]">
      <div class="md:col-span-7 lg:col-span-7 relative z-10">
        <h1
          class="display hero-rise hero-rise-1 text-[clamp(40px,6.4vw,84px)] text-hero-fg"
        >
          Columbia CS students.<br />Real software. Free for NYC.
        </h1>

        <p
          class="hero-rise hero-rise-2 mt-7 max-w-[56ch] text-[16px] md:text-[18px] leading-[1.55] text-white/85"
        >
          {hero.subhead}
        </p>

        <div class="hero-rise hero-rise-3 mt-9 flex flex-wrap items-center gap-3">
          <a href={WAITLIST_URL} class="btn-light">
            {hero.primaryCta.label}
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a href={hero.ghostCta.href} class="btn-light-ghost">
            {hero.ghostCta.label}
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <div
        class="md:col-span-5 lg:col-span-5 hero-rise hero-rise-4 flex justify-center md:justify-end"
      >
        <div class="aspect-square w-[260px] sm:w-[340px] md:w-[400px] lg:w-[460px]">
          <HeroCubes />
        </div>
      </div>
    </div>

    <!-- Tab bar -->
    <div
      class="hero-rise hero-rise-5 mt-12 md:mt-16 border-t border-white/15 pt-4"
    >
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-6 gap-y-3">
        {
          tabs.map((t, i) => (
            <div class="flex items-baseline gap-2 text-white/90 text-[13px]">
              <span class="font-medium tracking-tight">{t.label}</span>
              <span class="text-white/55">{t.subtitle}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
