---
import { hero, WAITLIST_URL } from "../content";
import HeroMap from "./HeroMap.astro";

const tabs = [
  { label: "Scope" },
  { label: "Match" },
  { label: "Build" },
  { label: "Review" },
  { label: "Ship" },
  { label: "Hand off" },
];
---

<section
  id="top"
  class="relative isolate overflow-hidden bg-hero-bg text-hero-fg"
>
  <div class="container-x relative pt-36 md:pt-40 pb-10 flex flex-col min-h-screen">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center flex-1">
      <div class="md:col-span-7 lg:col-span-7 relative z-10">
        <h1
          class="display hero-rise hero-rise-1 text-[clamp(44px,6.4vw,92px)] text-hero-fg"
        >
          Free software<br />for&nbsp;<span class="nyc-stamp" aria-label="NYC">
            <span class="nyc-stamp-micro" aria-hidden="true">Columbia CS</span>
            <span class="nyc-stamp-word" aria-hidden="true">NYC</span>
            <span class="nyc-stamp-micro" aria-hidden="true">Est. 2026</span>
          </span>.
        </h1>

        <p
          class="hero-rise hero-rise-2 mt-7 max-w-[58ch] text-[16px] md:text-[18px] leading-[1.55] text-white/85"
        >
          <span class="text-white font-medium">Columbia Software Solutions:</span>
          {" "}free software for nonprofits and small businesses. We scope,
          build, and ship in 1–2 months. Built and run by Columbia students.
          Started in NYC, Spring 2026.
        </p>

        <div class="hero-rise hero-rise-3 mt-9 flex flex-wrap items-center gap-3">
          <a
            href={WAITLIST_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-light"
          >
            {hero.primaryCta.label}
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a
            href={hero.ghostCta.href}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-light-ghost"
          >
            {hero.ghostCta.label}
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <div
        class="md:col-span-5 lg:col-span-5 hero-rise hero-rise-4 flex justify-center md:justify-end"
      >
        <div class="w-full max-w-[440px]">
          <HeroMap />
        </div>
      </div>
    </div>

    <!-- Tab bar -->
    <div
      class="hero-rise hero-rise-5 mt-12 md:mt-16 border-t border-white/15 pt-4"
    >
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-6 gap-y-3">
        {
          tabs.map((t) => (
            <div class="text-white/85 text-[13px] font-medium tracking-tight">
              {t.label}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .nyc-stamp {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.07em;
    min-width: 2.36em;
    margin-right: 0.04em;
    padding: 0.1em 0.14em 0.09em;
    border: 0.027em solid var(--accent);
    outline: 0.012em solid color-mix(in srgb, var(--accent) 60%, transparent);
    outline-offset: 0.052em;
    background: color-mix(in srgb, var(--accent) 7%, transparent);
    box-shadow: 0.055em 0.055em 0 color-mix(in srgb, var(--accent) 38%, transparent);
    color: var(--accent);
    line-height: 0.74;
    transform: rotate(-1.2deg);
  }

  .nyc-stamp-word {
    letter-spacing: -0.075em;
  }

  .nyc-stamp-micro {
    font-size: 0.105em;
    font-weight: 600;
    letter-spacing: 0.11em;
    line-height: 1;
    text-transform: uppercase;
  }
</style>
