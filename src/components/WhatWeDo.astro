---
// Each row: a meaningful thin-line icon (multiple SVG elements rather
// than a single path string so we can compose proper shapes), the
// title, and the body copy.
type Row = {
  icon: "pair" | "check" | "arrow";
  title: string;
  body: string;
};

const rows: Row[] = [
  {
    icon: "pair",
    title: "Real clients.",
    body: "We pair Columbia engineers with NYC nonprofits and small businesses. We scope the work, build the product, and hand it off.",
  },
  {
    icon: "check",
    title: "Senior review.",
    body: "Senior advisors from BCV, OpenAI, and HBS review scope and code.",
  },
  {
    icon: "arrow",
    title: "Shipped in a semester.",
    body: "Projects run 1–2 months. Our first two clients shipped in Spring 2026.",
  },
];
---

<section id="work" class="reveal py-20 md:py-24 border-b border-line">
  <div class="container-x">
    <p class="eyebrow">What we do</p>
    <h2
      class="display mt-5 max-w-[18ch] text-[clamp(34px,5vw,64px)] text-fg"
    >
      How we work.
    </h2>

    <div class="mt-14 space-y-10 md:space-y-12">
      {
        rows.map((row) => (
          <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-baseline border-t border-line pt-8 md:pt-10">
            <div class="md:col-span-5 flex items-center gap-4">
              <div class="h-9 w-9 flex-shrink-0 rounded-full border border-fg/25 flex items-center justify-center text-fg/80">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  {row.icon === "pair" && (
                    <>
                      <circle cx="9" cy="12" r="4" />
                      <circle cx="15" cy="12" r="4" />
                    </>
                  )}
                  {row.icon === "check" && (
                    <>
                      <circle cx="12" cy="12" r="9" />
                      <path d="M8 12.5 L11 15.5 L16.5 9.5" />
                    </>
                  )}
                  {row.icon === "arrow" && (
                    <>
                      <path d="M7 17 L17 7" />
                      <path d="M9 7 L17 7 L17 15" />
                    </>
                  )}
                </svg>
              </div>
              <h3 class="display text-[clamp(22px,2.2vw,30px)] text-fg leading-[1.05]">
                {row.title}
              </h3>
            </div>
            <p class="md:col-span-7 text-[16px] md:text-[17px] leading-[1.6] text-fg/80 max-w-[60ch]">
              {row.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
