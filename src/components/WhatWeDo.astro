---
const rows = [
  {
    iconPath:
      "M12 2 L22 12 L12 22 L2 12 Z M12 6 L18 12 L12 18 L6 12 Z",
    title: ["Real clients,", "real shipping."],
    body: "No mock projects, no tutorials. CSS pairs Columbia engineers with NYC nonprofits and small businesses who need software but can't afford a dev shop. We scope, build, and hand off — for free.",
  },
  {
    iconPath:
      "M3 12 L9 6 L15 12 L21 6 M3 12 L9 18 L15 12 L21 18",
    title: ["Senior mentorship,", "founder energy."],
    body: "Advisors from BCV, OpenAI, and HBS. We run like a startup, not a club: weekly standups, code review, post-mortems.",
  },
  {
    iconPath:
      "M4 4 H20 V20 H4 Z M4 4 L20 20 M20 4 L4 20",
    title: ["Built in a semester.", "Used for years."],
    body: "Our first two clients shipped production software in Fall 2025. The code is still running.",
  },
];
---

<section id="work" class="reveal py-24 md:py-32 border-b border-line">
  <div class="container-x">
    <p class="eyebrow">What we do</p>
    <h2
      class="display mt-5 max-w-[22ch] text-[clamp(34px,5vw,64px)] text-fg"
    >
      Student tech consulting, run like a startup.
    </h2>

    <div class="mt-16 space-y-12 md:space-y-14">
      {
        rows.map((row) => (
          <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-start border-t border-line pt-10 md:pt-12">
            <div class="md:col-span-1 flex md:justify-start">
              <div class="h-10 w-10 rounded-full border border-fg/30 flex items-center justify-center text-fg/80">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={row.iconPath} />
                </svg>
              </div>
            </div>
            <h3 class="md:col-span-5 display text-[clamp(24px,2.4vw,32px)] text-fg leading-[1.05]">
              {row.title[0]}
              <br />
              {row.title[1]}
            </h3>
            <p class="md:col-span-6 text-[16px] md:text-[17px] leading-[1.6] text-fg/80">
              {row.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
