---
const rows = [
  {
    iconPath:
      "M12 2 L22 12 L12 22 L2 12 Z M12 6 L18 12 L12 18 L6 12 Z",
    title: ["Real clients."],
    body: "We pair Columbia engineers with NYC nonprofits and small businesses. We scope the work, build the product, and hand it off.",
  },
  {
    iconPath: "M3 12 L9 6 L15 12 L21 6 M3 12 L9 18 L15 12 L21 18",
    title: ["Senior review."],
    body: "Senior advisors from BCV, OpenAI, and HBS review scope and code.",
  },
  {
    iconPath: "M4 4 H20 V20 H4 Z M4 4 L20 20 M20 4 L4 20",
    title: ["Shipped in a semester."],
    body: "Projects run 1–2 months. Our first two clients shipped in Spring 2026.",
  },
];
---

<section id="work" class="reveal py-20 md:py-24 border-b border-line">
  <div class="container-x">
    <p class="eyebrow">What we do</p>
    <h2
      class="display mt-5 max-w-[18ch] text-[clamp(34px,5vw,64px)] text-fg"
    >
      How we work.
    </h2>

    <div class="mt-14 space-y-10 md:space-y-12">
      {
        rows.map((row) => (
          <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-start border-t border-line pt-8 md:pt-10">
            <div class="md:col-span-5 flex items-start gap-4">
              <div class="mt-1 h-9 w-9 flex-shrink-0 rounded-full border border-fg/25 flex items-center justify-center text-fg/75">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={row.iconPath} />
                </svg>
              </div>
              <h3 class="display text-[clamp(22px,2.2vw,30px)] text-fg leading-[1.05]">
                {row.title[0]}
                {row.title[1] && (
                  <>
                    <br />
                    {row.title[1]}
                  </>
                )}
              </h3>
            </div>
            <p class="md:col-span-7 text-[16px] md:text-[17px] leading-[1.6] text-fg/80 max-w-[60ch]">
              {row.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
