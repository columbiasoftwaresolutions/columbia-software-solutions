---
/**
 * Hero scene — terminal animation.
 * A small mock terminal pane on the dark hero. Types out a short
 * sequence of lines on load, then sits with a blinking cursor.
 * Pure CSS — `ch` units + `steps()` on a width animation give the
 * crisp character-by-character typewriter effect.
 *
 * Direct evolution of the personality from the original CSS site.
 */

// Each line: visible text + char count (for typing duration + final width).
// `chars` should match the visible length so `width: <chars>ch` fits exactly.
const lines = [
  {
    cls: "cmd",
    prompt: "$",
    text: "css init --fall-2026",
    chars: 23, // "$ css init --fall-2026" (with prompt + space)
    delay: 0.4,
    type: 1.1,
  },
  {
    cls: "out",
    text: "→ matching engineers · clients",
    chars: 30,
    delay: 1.7,
    type: 1.3,
  },
  {
    cls: "out",
    text: "→ building software for nyc",
    chars: 27,
    delay: 3.2,
    type: 1.2,
  },
  {
    cls: "out",
    text: "→ shipping to production",
    chars: 24,
    delay: 4.6,
    type: 1.1,
  },
  {
    cls: "ok",
    text: "✓ deployed.",
    chars: 11,
    delay: 5.9,
    type: 0.6,
  },
];
---

<div class="terminal-wrap" aria-hidden="true">
  <div class="terminal">
    <div class="terminal-bar">
      <span class="dot d-red"></span>
      <span class="dot d-yel"></span>
      <span class="dot d-grn"></span>
      <span class="bar-title">css.sh</span>
    </div>
    <div class="terminal-body">
      {
        lines.map((line, i) => (
          <div
            class={`line line-${line.cls}`}
            style={`--chars: ${line.chars}ch; --type: ${line.type}s; --delay: ${line.delay}s;`}
          >
            {line.prompt && <span class="prompt">{line.prompt}</span>}
            <span class="content">{line.text}</span>
          </div>
        ))
      }
      <!-- Blinking cursor sits below the last line once everything is typed -->
      <div class="line line-cursor">
        <span class="prompt">$</span>
        <span class="cursor"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .terminal-wrap {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  .terminal {
    width: 100%;
    max-width: 420px;
    background: #1c1c1c;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 28px 70px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(13, 60, 252, 0.22),
      0 0 60px rgba(13, 60, 252, 0.18);
    opacity: 0;
    transform: translateY(8px);
    animation: term-in 600ms cubic-bezier(0.2, 0.7, 0.2, 1) 100ms forwards;
  }

  @keyframes term-in {
    to { opacity: 1; transform: none; }
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 14px;
    background: #232323;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: block;
  }
  .d-red { background: #ff5f57; }
  .d-yel { background: #febc2e; }
  .d-grn { background: #28c840; }

  .bar-title {
    margin-left: 12px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.5px;
  }

  .terminal-body {
    padding: 20px 22px 22px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 13.5px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ============================================================
     Typewriter rows
     Each `.line` uses width animation in `ch` units.
     `display: inline-block` so width animates cleanly.
     Wrapper `.line` is hidden until its animation runs.
     ============================================================ */

  .line {
    display: block;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
    max-width: var(--chars, 100%);
    animation: type var(--type, 1s) steps(40, end) var(--delay, 0s) both;
  }

  @keyframes type {
    from { width: 0; }
    to { width: var(--chars, 100%); }
  }

  .prompt {
    color: #0d3cfc;
    font-weight: 600;
    margin-right: 0.55ch;
  }

  .content {
    color: inherit;
  }

  .line-cmd .content { color: rgba(255, 255, 255, 0.95); }
  .line-out .content { color: rgba(255, 255, 255, 0.6); }
  .line-ok  .content { color: #28c840; font-weight: 500; }

  /* ============================================================
     Cursor — appears after the last line has typed, then blinks.
     ============================================================ */
  .line-cursor {
    width: auto;
    max-width: none;
    overflow: visible;
    opacity: 0;
    animation: cursor-in 300ms ease-out 6.6s forwards;
  }
  @keyframes cursor-in {
    to { opacity: 1; }
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 16px;
    background: #ffffff;
    margin-left: 1px;
    vertical-align: text-bottom;
    animation: blink 1s steps(2, jump-none) 6.6s infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .line, .line-cursor {
      animation: none;
      width: var(--chars, auto);
      max-width: var(--chars, none);
      opacity: 1;
    }
    .cursor {
      animation: none;
      opacity: 1;
    }
  }
</style>
