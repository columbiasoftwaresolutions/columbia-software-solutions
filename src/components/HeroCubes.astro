---
/**
 * Isometric floating cubes — SVG approximation of DOSS's Lottie hero motif.
 * Electric-blue cubes against the dark hero background, with a subtle
 * dot grid behind them. Three cubes drift independently.
 */
---

<div class="cubes" aria-hidden="true">
  <svg viewBox="-200 -200 400 400" class="cubes-svg" fill="none">
    <defs>
      <linearGradient id="cubeTop" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#3B66FF" />
        <stop offset="1" stop-color="#0D3CFC" />
      </linearGradient>
      <linearGradient id="cubeLeft" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#0D3CFC" />
        <stop offset="1" stop-color="#0830C8" />
      </linearGradient>
      <linearGradient id="cubeRight" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#1A4CFF" />
        <stop offset="1" stop-color="#0A35E0" />
      </linearGradient>

      <!-- Cube path: top face, left face, right face -->
      <g id="cube">
        <polygon
          points="0,-60 52,-30 0,0 -52,-30"
          fill="url(#cubeTop)"
          stroke="rgba(255,255,255,0.35)"
          stroke-width="1"
          stroke-linejoin="round"
        ></polygon>
        <polygon
          points="-52,-30 0,0 0,60 -52,30"
          fill="url(#cubeLeft)"
          stroke="rgba(255,255,255,0.25)"
          stroke-width="1"
          stroke-linejoin="round"
        ></polygon>
        <polygon
          points="52,-30 0,0 0,60 52,30"
          fill="url(#cubeRight)"
          stroke="rgba(255,255,255,0.3)"
          stroke-width="1"
          stroke-linejoin="round"
        ></polygon>
      </g>
    </defs>

    <!-- Faint dot grid behind cubes -->
    <g class="dots" stroke="none" fill="rgba(255,255,255,0.22)">
      <circle cx="-160" cy="-120" r="1.4"></circle>
      <circle cx="-100" cy="-150" r="1.4"></circle>
      <circle cx="-40" cy="-130" r="1.4"></circle>
      <circle cx="20" cy="-160" r="1.4"></circle>
      <circle cx="80" cy="-110" r="1.4"></circle>
      <circle cx="140" cy="-140" r="1.4"></circle>
      <circle cx="170" cy="-80" r="1.4"></circle>
      <circle cx="-180" cy="-30" r="1.4"></circle>
      <circle cx="160" cy="20" r="1.4"></circle>
      <circle cx="-140" cy="120" r="1.4"></circle>
      <circle cx="-60" cy="150" r="1.4"></circle>
      <circle cx="40" cy="140" r="1.4"></circle>
      <circle cx="120" cy="160" r="1.4"></circle>
      <circle cx="-180" cy="60" r="1.4"></circle>
      <circle cx="180" cy="100" r="1.4"></circle>
    </g>

    <!-- Cube stack -->
    <g class="cube-back" transform="translate(-60, -50)">
      <use href="#cube"></use>
    </g>
    <g class="cube-mid" transform="translate(60, -20)">
      <use href="#cube"></use>
    </g>
    <g class="cube-front" transform="translate(-10, 60)">
      <use href="#cube"></use>
    </g>
  </svg>
</div>

<style>
  .cubes {
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }
  .cubes-svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .cube-back,
  .cube-mid,
  .cube-front {
    transform-origin: center;
    transform-box: fill-box;
    filter: drop-shadow(0 14px 30px rgba(13, 60, 252, 0.35));
  }

  .cube-back {
    animation: float-a 7s ease-in-out infinite;
  }
  .cube-mid {
    animation: float-b 9s ease-in-out infinite;
  }
  .cube-front {
    animation: float-c 6s ease-in-out infinite;
  }

  .dots circle {
    animation: dot-pulse 3.6s ease-in-out infinite;
  }
  .dots circle:nth-child(odd) {
    animation-delay: 1.2s;
  }

  @keyframes float-a {
    0%, 100% { transform: translate(-60px, -50px); }
    50% { transform: translate(-60px, -64px); }
  }
  @keyframes float-b {
    0%, 100% { transform: translate(60px, -20px); }
    50% { transform: translate(60px, -34px); }
  }
  @keyframes float-c {
    0%, 100% { transform: translate(-10px, 60px); }
    50% { transform: translate(-10px, 46px); }
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 0.22; }
    50% { opacity: 0.55; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cube-back, .cube-mid, .cube-front, .dots circle {
      animation: none;
    }
  }
</style>
