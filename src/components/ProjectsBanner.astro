---
import { caseStudies } from "../content";

const shipped = caseStudies.filter((c) => c.status === "shipped").length;
const inProgress = caseStudies.filter((c) => c.status === "in-progress").length;
const total = caseStudies.length;
---

<a
  href="/projects"
  id="cases"
  class="reveal projects-banner block py-20 md:py-24 group"
  aria-label="View all projects"
>
  <div class="container-x">
    <p class="banner-eyebrow">Work</p>
    <div class="mt-5 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-end">
      <div class="md:col-span-9">
        <h2 class="display text-[clamp(40px,6vw,80px)] leading-[1]">
          Our projects.
          <span class="banner-arrow" aria-hidden="true">→</span>
        </h2>
        <p class="mt-6 max-w-[60ch] text-[17px] md:text-[18px] leading-[1.55] banner-sub">
          {total} client engagements — {shipped} shipped, {inProgress} in progress.
        </p>
      </div>
      <div class="md:col-span-3 flex md:justify-end">
        <span class="view-cta">View all projects</span>
      </div>
    </div>
  </div>
</a>

<style>
  .projects-banner {
    background: var(--hero-accent);
    color: #ffffff;
    text-decoration: none;
    transition: background 200ms ease;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .projects-banner:hover {
    background: rgb(var(--accent-dark-rgb));
  }
  .projects-banner:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: -6px;
  }

  .banner-eyebrow {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .banner-sub {
    color: rgba(255, 255, 255, 0.85);
  }

  .banner-arrow {
    display: inline-block;
    margin-left: 0.1em;
    transition: transform 220ms cubic-bezier(0.2, 0.7, 0.2, 1);
    color: #ffffff;
  }
  .projects-banner:hover .banner-arrow {
    transform: translateX(0.18em);
  }

  .view-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.75);
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 4px;
    transition: color 200ms, border-color 200ms;
  }
  .projects-banner:hover .view-cta {
    color: #ffffff;
    border-color: #ffffff;
  }
</style>
