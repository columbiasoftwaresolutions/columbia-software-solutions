---
import { caseStudies } from "../content";

interface Props {
  /** Used on the dedicated /projects page — tightens top padding
      since the page already pads from the fixed nav above. */
  compact?: boolean;
}
const { compact = false } = Astro.props;

// Render shipped projects first, then in-progress, so the page reads
// "here's what we've done → here's what we're doing now."
const ordered = [...caseStudies].sort((a, b) => {
  if (a.status === b.status) return 0;
  return a.status === "shipped" ? -1 : 1;
});
---

<section
  id="cases"
  class:list={[
    "reveal border-b border-line",
    compact ? "pt-8 md:pt-10 pb-20 md:pb-24" : "py-20 md:py-24",
  ]}
>
  <div class="container-x">
    <p class="eyebrow">Work</p>
    <h2 class="display mt-5 max-w-[18ch] text-[clamp(34px,5vw,64px)] text-fg">
      Our work.
    </h2>

    <div class="mt-16 space-y-20 md:space-y-28">
      {
        ordered.map((cs, i) => {
          const reversed = i % 2 === 1;
          const inProgress = cs.status === "in-progress";
          return (
            <article
              id={`case-${cs.id}`}
              class={`grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-center scroll-mt-28 ${reversed ? "md:[&>.media]:order-2" : ""}`}
            >
              {cs.image ? (
                <img
                  src={cs.image}
                  alt={cs.imageAlt}
                  class="media md:col-span-6 w-full h-auto object-contain bg-bg-alt border border-line"
                  loading="lazy"
                />
              ) : (
                <div
                  class={`media md:col-span-6 aspect-[4/3] w-full bg-bg-alt border border-line flex items-center justify-center text-[11px] uppercase tracking-eyebrow text-muted ${inProgress ? "border-dashed" : ""}`}
                  role="img"
                  aria-label={cs.imageAlt}
                >
                  {inProgress ? "Coming soon" : `Placeholder — ${cs.imageAlt}`}
                </div>
              )}

              <div class="md:col-span-6">
                {inProgress && (
                  <span class="status-badge status-in-progress">
                    <span class="status-dot" aria-hidden="true" />
                    In progress
                  </span>
                )}

                <p class={`eyebrow ${inProgress ? "mt-3" : ""}`}>{cs.tagline}</p>
                <h3 class="display mt-4 text-[clamp(26px,3vw,40px)] text-fg leading-[1.05]">
                  {cs.clientName}
                </h3>
                <p class="mt-5 text-[16px] md:text-[17px] leading-[1.6] text-fg/80 max-w-[60ch]">
                  {cs.description}
                </p>

                {cs.stack && cs.stack.length > 0 && (
                  <ul class="mt-6 flex flex-wrap gap-2">
                    {cs.stack.map((s) => (
                      <li class="rounded-full border border-line bg-bg-alt px-3 py-1 text-[12px] font-medium tracking-tight text-fg/80">
                        {s}
                      </li>
                    ))}
                  </ul>
                )}

                {cs.stats && cs.stats.length > 0 && (
                  <dl class="mt-8 grid grid-cols-3 gap-4 border-t border-line pt-6">
                    {cs.stats.map((s) => (
                      <div>
                        <dt class="display text-[clamp(22px,2.6vw,34px)] text-fg leading-[1]">
                          {s.value}
                        </dt>
                        <dd class="mt-2 text-[11px] uppercase tracking-eyebrow text-muted">
                          {s.label}
                        </dd>
                      </div>
                    ))}
                  </dl>
                )}

                {cs.attribution && (
                  <p class="mt-6 text-[12px] uppercase tracking-eyebrow text-muted">
                    {cs.attribution}
                  </p>
                )}

                {cs.press && (
                  <div class="mt-8">
                    <a
                      href={cs.press.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-[13px] uppercase tracking-eyebrow text-fg/70 border-b border-fg/30 pb-1 transition-colors hover:text-fg hover:border-fg"
                    >
                      {cs.press.label}
                      <span aria-hidden="true">↗</span>
                    </a>
                  </div>
                )}

                {cs.url && (
                  <div class="mt-8">
                    <a
                      href={cs.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-[13px] uppercase tracking-eyebrow text-fg/70 border-b border-fg/30 pb-1 transition-colors hover:text-fg hover:border-fg"
                    >
                      Visit client
                      <span aria-hidden="true">↗</span>
                    </a>
                  </div>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    padding: 4px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--bg-alt);
  }
  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: transparent;
    border: 1.5px solid rgba(13, 60, 252, 0.85);
    box-shadow: 0 0 6px rgba(13, 60, 252, 0.35);
  }
</style>
