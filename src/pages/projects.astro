---
import Layout from "../layouts/Layout.astro";
import Banner from "../components/Banner.astro";
import Nav from "../components/Nav.astro";
import CaseStudies from "../components/CaseStudies.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Projects"
  description="Client engagements built by Columbia Software Solutions — shipped work and projects currently in progress."
>
  <Banner />
  <Nav />
  <main class="pt-24 md:pt-28">
    <CaseStudies compact />
  </main>
  <Footer />
</Layout>

<script>
  // Scroll-triggered reveal — IntersectionObserver, progressive enhancement.
  // (Same as home page; lives here so /projects gets the same fade-in.)
  const setup = () => {
    const els = document.querySelectorAll(".reveal");
    if (!("IntersectionObserver" in window)) return;
    els.forEach((el) => el.classList.add("reveal-armed"));
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.05 },
    );
    els.forEach((el) => io.observe(el));
  };
  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
