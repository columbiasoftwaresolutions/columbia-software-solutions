---
import Layout from "../layouts/Layout.astro";
import Banner from "../components/Banner.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Advisors from "../components/Advisors.astro";
import ParticleSwarm from "../components/ParticleSwarm.astro";
import ProjectsBanner from "../components/ProjectsBanner.astro";
import ForStudents from "../components/ForStudents.astro";
import ForClients from "../components/ForClients.astro";
import Team from "../components/Team.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Banner />
  <Nav />
  <main>
    <Hero />
    <Advisors />
    <ParticleSwarm />
    <ProjectsBanner />
    <ForStudents />
    <ForClients />
    <Team />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<script>
  // Scroll-triggered reveal — IntersectionObserver, progressive enhancement.
  const setup = () => {
    const els = document.querySelectorAll(".reveal");
    if (!("IntersectionObserver" in window)) return;
    // Arm the hide-state only after JS loads, so non-JS users see content.
    els.forEach((el) => el.classList.add("reveal-armed"));
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.05 },
    );
    els.forEach((el) => io.observe(el));
  };
  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
